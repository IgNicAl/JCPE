# ============================================================================
# JCPE - Variáveis de Ambiente (Template)
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# ============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS (MySQL)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=sua_senha_root_segura
MYSQL_DATABASE=jcpe_db
MYSQL_USER=jcpe_user
MYSQL_PASSWORD=sua_senha_segura

DB_PORT=3306

# -----------------------------------------------------------------------------
# REDIS (Cache)
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# LLM PROVIDER (Escolha um)
# -----------------------------------------------------------------------------
# Opção 1: Gemini (Google AI)
LLM_PROVIDER=gemini
GEMINI_API_KEY=sua_api_key_aqui

# Opção 2: Ollama (Local - descomente as linhas abaixo e comente as acima)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=gemma2:9b

# -----------------------------------------------------------------------------
# SPRING BOOT
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
