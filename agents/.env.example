# ============================================================================
# CONFIGURAÇÃO DO SISTEMA DE AGENTES JCPE
# ============================================================================
# Copie este arquivo para .env e ajuste conforme necessário
# ============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS MYSQL
# -----------------------------------------------------------------------------
# IMPORTANTE: Use 'localhost' quando rodar fora do Docker
# Use 'database' apenas dentro do Docker Compose
DB_USER=root
DB_PASSWORD=senha
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jcpe_db

# -----------------------------------------------------------------------------
# API GEMINI (Google AI)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyAjNWL8VQEDUw69F5oClWy5U_0YTuC2uEA

# -----------------------------------------------------------------------------
# REDIS (Opcional - Cache)
# -----------------------------------------------------------------------------
# Se Redis não estiver rodando, o sistema funciona com fallback (sem cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# CONFIGURAÇÃO DA APLICAÇÃO
# -----------------------------------------------------------------------------
# Ambiente de execução
ENV=development

# Logging
LOG_LEVEL=INFO
