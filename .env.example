# ===================================
# Configuração do Agente (Python)
# ===================================
# Chave da API do Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# Chave da NewsAPI (https://newsapi.org/)
NEWS_API_KEY=SUA_CHAVE_NEWSAPI_AQUI

# ===================================
# Configuração do Banco de Dados (Usado por Java e Python)
# ===================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jcpm_db
DB_USER=root
DB_PASSWORD=SUA_SENHA_DO_BANCO_DE_DADOS_AQUI

# ===================================
# Configuração do Backend (Java)
# ===================================
# Segredo para assinatura dos tokens JWT (Java)
JWT_SECRET=UmSegredoLongoParaProtegerTokensJWTSubstituaIsso
# Expiração do token (Java) - 86400000ms = 24 horas
JWT_EXPIRATION=86400000
